# Required in production. In dev, defaults are used if these are unset.
JWT_SECRET=change-me-to-a-32-byte-random-string

# First admin owner — created on cold start if no users exist.
ADMIN_OWNER_EMAIL=owner@dancehyderabad.com
ADMIN_OWNER_INITIAL_PASSWORD=change-me-on-first-login

# Optional analytics
NEXT_PUBLIC_GA4_ID=

# Production object storage (Vercel Blob). Leave blank in dev — local filesystem is used.
BLOB_READ_WRITE_TOKEN=
