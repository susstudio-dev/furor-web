# ─── Auth ───────────────────────────────────────────────────────────────────
# Sign the admin session JWT. MUST be a strong 32+ char random string in prod.
JWT_SECRET=change-me-to-a-32-byte-random-string

# Admin owner.
#  • Dev: an owner is seeded into data/users.json on first run from these.
#  • Prod (Vercel): the owner is THIS env identity — no DB needed.
ADMIN_OWNER_EMAIL=owner@dancehyderabad.com
# Either provide a bcrypt hash (preferred for prod)…
ADMIN_OWNER_PASSWORD_HASH=
# …or a plaintext password (hashed in memory; fine to start with).
ADMIN_OWNER_INITIAL_PASSWORD=change-me

# ─── Storage ────────────────────────────────────────────────────────────────
# Leave BLANK in dev → content/versions/uploads use the local filesystem.
# Set in prod (Vercel auto-injects it when a Blob store is linked) → content,
# version history and image uploads persist to Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# ─── Optional ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=
# Only set by the GitHub Pages workflow (static mirror under /furor-web).
NEXT_PUBLIC_BASE_PATH=
